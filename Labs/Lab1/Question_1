#include<iostream>
#include<string>
using namespace std;

int main(){
	string RollNumber;
    float marks[5];
    
    cout<<"Enter Roll Number : (CT-25053)-format"<<endl;
    cin>>RollNumber;
    
    float sum = 0.0;
    
    for(int i = 0 ; i < 5 ; i++){
    	cout<<"Enter marks of Subject : "<<i+1<<endl;
    	cin>>marks[i];
    	if(! (marks[i] >= 0 && marks[i] <= 100)){
    		cout<<"[Invalid Input] : Marks Range must be between(0-100)"<<endl;
    		i--;
		}
    	sum+=marks[i];
	}
	
	float average = sum/5.0;
	
	cout<<"Marks of Roll Number "<<RollNumber<<" are as follows :"<<endl;
	for(int i = 0; i < 5 ; i++){
		cout<<"Subject "<<i+1<<" is : "<<marks[i]<<endl;
	}
	cout<<"Average marks are : "<<average<<endl;
	
	return 0;
}
